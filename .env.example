# Copy this file to .env locally if needed.
# Never commit real API keys, OAuth tokens, refresh tokens, cookies, or personal data.

DATABASE_URL=
AUTH_SECRET=
AUTH_URL=http://127.0.0.1:3000
GITHUB_ID=
GITHUB_SECRET=
GITHUB_ALLOWED_USERS=Cartterr
GITHUB_ALLOWED_EMAILS=
SCHEDULED_SCAN_SECRET=

# Provider credentials. Missing credentials are treated as a skipped provider.
TICKETMASTER_API_KEY=
JAMBASE_API_KEY=
SEATGEEK_CLIENT_ID=
SEATGEEK_CLIENT_SECRET=
PREDICTHQ_ACCESS_TOKEN=
EVENTBRITE_TOKEN=

# Disabled by default in v1 unless valid licensed/partner credentials exist.
SONGKICK_API_KEY=
BANDSINTOWN_APP_ID=
BANDSINTOWN_ENABLED=false

# Local development only. Do not enable in production.
DEV_AUTH_BYPASS=false
